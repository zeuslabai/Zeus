# ═══════════════════════════════════════════════════════════
# ZEUS — Environment Variables Template
# Copy to .env and fill in your values.
# Config file: ~/.zeus/config.toml
# ═══════════════════════════════════════════════════════════

# ── LLM Providers ───────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Ollama (optional — defaults to http://localhost:11434)
OLLAMA_HOST=

# Embeddings
VOYAGE_API_KEY=

# ── Zeus Server ──────────────────────────────────────────────
ZEUS_INSTANCE_NAME=zeus
ZEUS_API_PORT=8080
ZEUS_API_KEY=
ZEUS_API_KEYS=                   # comma-separated for multi-key auth
ZEUS_WEBHOOK_SECRET=

# ── Channels — Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_2FA_PASSWORD=           # MTProto 2FA (if set on account)
TELEGRAM_ALLOWED_USERS=          # comma-separated user IDs
TELEGRAM_CODE=                   # one-time login code (MTProto)
TELEGRAM_RELAY_SESSION=          # persisted session string

# ── Channels — Discord ──────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Channels — Slack ────────────────────────────────────────
SLACK_BOT_TOKEN=                 # xoxb-...

# ── Channels — WhatsApp ─────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Channels — Matrix ───────────────────────────────────────
MATRIX_HOMESERVER=
MATRIX_USER=
MATRIX_PASSWORD=
MATRIX_ACCESS_TOKEN=             # set after first login to skip password auth

# ── Channels — Signal ───────────────────────────────────────
SIGNAL_ACCOUNT=                  # phone number registered with signal-cli
SIGNAL_CLI_PATH=                 # path to signal-cli binary

# ── Channels — iMessage / BlueBubbles ───────────────────────
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# ── Channels — Teams ────────────────────────────────────────
TEAMS_ACCESS_TOKEN=

# ── Channels — Mattermost ───────────────────────────────────
MATTERMOST_URL=
MATTERMOST_TOKEN=

# ── Channels — Feishu / Lark ────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ACCESS_TOKEN=

# ── Channels — Google Chat ──────────────────────────────────
GOOGLE_CHAT_TOKEN=
GOOGLE_CLOUD_PROJECT=

# ── Channels — LINE ─────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=

# ── Channels — Twitch ───────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_ACCESS_TOKEN=

# ── Channels — IRC ──────────────────────────────────────────
IRC_SERVER=
IRC_NICK=

# ── Channels — MQTT ─────────────────────────────────────────
MQTT_BROKER_URL=
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=zeus
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=zeus

# ── Channels — Nostr ────────────────────────────────────────
NOSTR_PRIVATE_KEY=
NOSTR_RELAY_URL=

# ── Channels — Nextcloud Talk ───────────────────────────────
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_TOKEN=

# ── Channels — Zalo ─────────────────────────────────────────
ZALO_ACCESS_TOKEN=
ZALO_OA_ID=

# ── Channels — WebChat ──────────────────────────────────────
WEBCHAT_URL=
WEBCHAT_API_KEY=

# ── Voice — Twilio ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=             # outbound caller ID (+E.164)
TWILIO_FROM_NUMBER=
TWILIO_INBOUND_NUMBER=
TWILIO_WEBHOOK_URL=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WHATSAPP_SANDBOX=

# ── Voice — Telnyx ──────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=

# ── Voice — Plivo ───────────────────────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# ── STT / TTS ────────────────────────────────────────────────
ZEUS_STT_PROVIDER=               # whisper | groq
ZEUS_TTS_PROVIDER=               # openai | piper | say
ZEUS_WHISPER_URL=                # local Whisper server URL
ZEUS_PIPER_URL=                  # local Piper TTS server URL
ZEUS_RECORDING_BUCKET=           # S3/R2 bucket for call recordings
# Legacy WHISPER_URL var removed — use ZEUS_WHISPER_URL above
ELEVENLABS_API_KEY=
KOKORO_API_URL=

# ── Voice Webhooks ───────────────────────────────────────────
ZEUS_VOICE_WEBHOOK_URL=          # public URL for Twilio/Telnyx callbacks
ZEUS_VOICE_INBOUND_PATH=/voice/inbound

# ── Tunneling ────────────────────────────────────────────────
ZEUS_TUNNEL_PROVIDER=            # ngrok | cloudflare | tailscale
ZEUS_TUNNEL_URL=
NGROK_AUTH_TOKEN=
TAILSCALE_HOSTNAME=

# ── Skills / Extensions ──────────────────────────────────────
ZEUS_SKILLS_DIR=~/.zeus/skills
CLAWHUB_BASE_URL=https://clawhub.dev
CLAWHUB_AUTO_IMPORT=false

# ── Search ───────────────────────────────────────────────────
BRAVE_API_KEY=

# ── Image Generation ─────────────────────────────────────────
FOOOCUS_API_URL=http://localhost:7866
