{
  "permissions": {
    "allow": [
      "mcp__zeus__*",
      "Bash(ssh *)",
      "Bash(cargo *)",
      "Bash(git *)"
    ]
  },
  "model": "sonnet",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "mcpServers": {
    "zeus": {
      "command": "/usr/local/bin/zeus",
      "args": ["mcp"],
      "env": {
        "HOME": "{{HOME}}",
        "ZEUS_HOME": "{{HOME}}/.zeus"
      }
    }
  }
}
