<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zeus.deploy-poll</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ZEUS_REPO__/scripts/zeus-deploy/deploy-poll.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__ZEUS_USER_HOME__</string>
        <key>ZEUS_HOME</key>
        <string>__ZEUS_HOME__</string>
        <key>ZEUS_REPO</key>
        <string>__ZEUS_REPO__</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>__ZEUS_REPO__</string>

    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__ZEUS_HOME__/logs/deploy-poll.out.log</string>
    <key>StandardErrorPath</key>
    <string>__ZEUS_HOME__/logs/deploy-poll.err.log</string>
</dict>
</plist>
